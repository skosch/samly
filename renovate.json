{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "prHourlyLimit": 0,
    "prConcurrentLimit": 0,
    "rebaseWhen": "never",
    "labels": ["dependency-outdated"],
    "configMigration": true,
    "enabledManagers": ["mix"],
    "schedule": ["* 5-17 * * 1-5"],
    "extends": [
        "config:recommended",
        "helpers:pinGitHubActionDigests",
        ":automergePatch"
    ],
    "separateMinorPatch": true
}
